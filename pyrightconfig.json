{
    "include": [
        "app/**/*.py",
        "tests/**/*.py",
        "*.py"
    ],
    "exclude": [
        "**/__pycache__",
        "**/.venv",
        "**/node_modules"
    ],
    "venv": ".venv",
    "venvPath": ".",
    "executionEnvironments": [
        {
            "root": ".",
            "pythonVersion": "3.11",
            "pythonPlatform": "Windows",
            "extraPaths": [
                "."
            ]
        }
    ],
    "typeCheckingMode": "basic"
}
